
{
  "entities": {
    "Socio": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Socio",
      "type": "object",
      "description": "Represents a member of the Garage Music Club.",
      "properties": {
        "id": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "birthPlace": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "fiscalCode": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "postalCode": { "type": "string" },
        "whatsappConsent": { "type": "boolean" },
        "privacyConsent": { "type": "boolean" },
        "guardianFirstName": { "type": "string" },
        "guardianLastName": { "type": "string" },
        "guardianBirthDate": { "type": "string", "format": "date" },
        "membershipStatus": { "type": "string" },
        "joinDate": { "type": "string", "format": "date-time" },
        "expirationDate": { "type": "string", "format": "date-time" },
        "renewalDate": { "type": "string", "format": "date-time" },
        "membershipYear": { "type": "string" },
        "notes": { "type": "string" },
        "membershipFee": { "type": "number" },
        "qualifica": {
          "type": "array",
          "items": { "type": "string", "enum": ["FONDATORE", "VOLONTARIO", "MUSICISTA"] }
        },
        "tessera": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName"]
    },
    "AppConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppConfig",
      "type": "object",
      "description": "Global application settings like WhatsApp invite links.",
      "properties": {
        "whatsAppInviteLink1": { "type": "string", "format": "uri" },
        "whatsAppInviteLink2": { "type": "string", "format": "uri" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/membership_requests/{requestId}",
        "definition": {
          "entityName": "RichiestaIscrizione",
          "description": "Public membership requests."
        }
      },
      {
        "path": "/members/{memberId}",
        "definition": {
          "entityName": "Socio",
          "description": "Secure member records."
        }
      },
      {
        "path": "/settings/{configId}",
        "definition": {
          "entityName": "AppConfig",
          "description": "Application configuration."
        }
      },
      {
        "path": "/roles_admin/{adminId}",
        "definition": {
          "entityName": "Amministratore",
          "description": "Admin roles by UID."
        }
      }
    ]
  }
}
