{
  "entities": {
    "Socio": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Socio",
      "type": "object",
      "description": "Rappresenta un socio del Garage Music Club.",
      "properties": {
        "id": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "birthPlace": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "fiscalCode": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "postalCode": { "type": "string" },
        "whatsappConsent": { "type": "boolean" },
        "privacyConsent": { "type": "boolean" },
        "guardianFirstName": { "type": "string" },
        "guardianLastName": { "type": "string" },
        "guardianBirthDate": { "type": "string", "format": "date" },
        "membershipStatus": { "type": "string" },
        "joinDate": { "type": "string", "format": "date-time" },
        "expirationDate": { "type": "string", "format": "date-time" },
        "renewalDate": { "type": "string", "format": "date-time" },
        "membershipYear": { "type": "string" },
        "notes": { "type": "string" },
        "membershipFee": { "type": "number" },
        "qualifica": {
          "type": "array",
          "items": { "type": "string", "enum": ["FONDATORE", "VOLONTARIO", "MUSICISTA"] }
        },
        "tessera": { "type": "string" },
        "requestDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName"]
    },
    "AppConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppConfig",
      "type": "object",
      "description": "Impostazioni globali come i link WhatsApp.",
      "properties": {
        "whatsAppInviteLink1": { "type": "string", "format": "uri" },
        "whatsAppInviteLink2": { "type": "string", "format": "uri" }
      }
    },
    "Amministratore": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Amministratore",
      "type": "object",
      "description": "Ruolo amministrativo.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "email"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/membership_requests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/Socio" },
      "description": "Richieste pubbliche di iscrizione."
    },
    "/members/{memberId}": {
      "schema": { "$ref": "#/backend/entities/Socio" },
      "description": "Record sicuri dei soci."
    },
    "/settings/{configId}": {
      "schema": { "$ref": "#/backend/entities/AppConfig" },
      "description": "Configurazioni applicazione."
    },
    "/roles_admin/{adminId}": {
      "schema": { "$ref": "#/backend/entities/Amministratore" },
      "description": "Ruoli admin per UID."
    }
  }
}