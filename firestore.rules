rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Verifica se l'utente è un amministratore.
     * Un utente è admin se la sua email è quella predefinita o se esiste un documento in /roles_admin/{uid}
     */
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "garage.music.club2024@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }


    // Regole per le richieste di iscrizione
    match /membership_requests/{requestId} {
      // Chiunque può inviare una richiesta (create)
      allow create: if true;
      // Solo gli admin possono vedere o gestire le richieste
      allow read, update, delete: if isAdmin();
    }

    // Regole per i soci effettivi
    match /members/{memberId} {
      // Solo gli admin possono leggere, creare o modificare i dati dei soci
      allow read, write: if isAdmin();
    }

    // Regole per i soci eliminati (archivio)
    match /deleted_members/{memberId} {
      allow read, write: if isAdmin();
    }

    // Regole per il Log delle Attivita (Timeline)
    match /admin_logs/{logId} {
      allow create: if true; 
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Regole per i ruoli admin
    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Regole per le impostazioni generali
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Negazione globale per tutto il resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}