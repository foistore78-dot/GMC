rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email.matches("(?i)garage.music.club2024@gmail.com") ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // Public collection for submitting requests
    match /membership_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Secure collection for club members
    match /members/{memberId} {
      allow read, write: if isAdmin();
    }

    // Global settings (WhatsApp links etc)
    match /settings/{configId} {
      allow read, write: if isAdmin();
    }

    // Admin roles verification
    match /roles_admin/{adminId} {
      allow read: if request.auth != null && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }
  }
}