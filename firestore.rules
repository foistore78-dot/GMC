
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Controllo basato sull'email dell'amministratore o sulla presenza nella collezione roles_admin
      return request.auth.token.email == "garage.music.club2024@gmail.com" || 
             exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Pubblico può creare richieste di iscrizione. Gli admin le gestiscono.
     * @path /membership_requests/{membershipRequestId}
     */
    match /membership_requests/{membershipRequestId} {
      allow create: if true; 
      allow read, update, delete: if isSignedIn() && isAdmin();
    }

    /**
     * @description Solo gli admin possono leggere e scrivere nella collezione soci.
     * @path /members/{memberId}
     */
    match /members/{memberId} {
      allow read, write: if isSignedIn() && isAdmin();
    }

    /**
     * @description Ruoli amministrativi basati su UID.
     * @path /roles_admin/{adminId}
     */
    match /roles_admin/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if false; // Solo gestione manuale da console per sicurezza
    }
  }
}
